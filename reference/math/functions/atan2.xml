<refentry xml:id="function.atan2" xmlns="http://docbook.org/ns/docbook">
 <refnamediv>
  <refname>atan2</refname>
  <refpurpose>İki değişkenin ark tanjantı</refpurpose>
 </refnamediv>
 <refsect1 role="description">
  &reftitle.description;
   <methodsynopsis>
    <type>float</type><methodname>atan2</methodname>
    <methodparam><type>float</type><parameter>y</parameter></methodparam>
    <methodparam><type>float</type><parameter>x</parameter></methodparam>
   </methodsynopsis>
  <simpara>
   Bu işlev, <parameter>x</parameter> ve <parameter>y</parameter> bağımsız
   değişkenlerinin ark tanjantını hesaplar.
   <parameter>y</parameter> / <parameter>x</parameter> değerinin ark
   tanjantını hesaplamaya benzer; tek fark, sonucun ait olduğu çeyreğin
   belirlenmesinde her iki bağımsız değişkenin işaretinin de kullanılmasıdır.
  </simpara>
  <simpara>
   İşlev sonucu radyan cinsinden döndürür; bu değer -PI ile PI arasındadır
   (uçlar dahil).
  </simpara>
 </refsect1>
 <refsect1 role="parameters">
  &reftitle.parameters;
  <para>
   <variablelist>
    <varlistentry>
     <term><parameter>y</parameter></term>
     <listitem>
      <para>
       Bölünen bağımsız değişken.
      </para>
     </listitem>
    </varlistentry>
    <varlistentry>
     <term><parameter>x</parameter></term>
     <listitem>
      <para>
       Bölen bağımsız değişken.
      </para>
     </listitem>
    </varlistentry>
   </variablelist>
  </para>
 </refsect1>
 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <para>
   <parameter>y</parameter>/<parameter>x</parameter> değerinin radyan
   cinsinden ark tanjantı.
  </para>
 </refsect1>
 <refsect1 role="seealso">
  &reftitle.seealso;
  <para>
   <simplelist>
    <member><function>atan</function></member>
   </simplelist>
  </para>
 </refsect1>
</refentry>

